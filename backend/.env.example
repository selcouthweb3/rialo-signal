# Rialo Signal — Environment Variables
# Copy this to .env and fill in your keys

# CoinGecko (free tier — no key needed, but add for higher rate limits)
COINGECKO_API_KEY=

# Anthropic Claude API (for AI Narrator)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App config
APP_ENV=development
CACHE_TTL_SECONDS=30
PORT=8000

# Rialo SDK (not live yet — leave blank, used as stub)
RIALO_RPC_URL=
RIALO_SDK_KEY=
